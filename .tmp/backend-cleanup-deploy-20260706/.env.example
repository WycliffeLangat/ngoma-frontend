# Copy this to .env for local development
# In production (Railway/Render), set these as environment variables in the dashboard

SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=ngomacharts.co.ke,api.ngomacharts.co.ke,localhost
DATABASE_URL=postgresql://user:password@host:5432/dbname
CORS_ALLOWED_ORIGINS=https://ngomacharts.co.ke,https://www.ngomacharts.co.ke
CSRF_TRUSTED_ORIGINS=https://ngomacharts.co.ke,https://api.ngomacharts.co.ke

# For custom React CMS session auth when frontend/backend are on different domains:
# Use None only with HTTPS in production.
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
