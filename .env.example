# Copy this file to ".env" and fill in your deployed backend URL.
# Leave empty to use the bundled September 2025-May 2026 dataset.
# The AI Analyst is currently disabled in the app.

# When your Django backend is live, set this to its API base, e.g.:
# VITE_API_BASE=https://api.ngomacharts.co.ke/api/v1
VITE_API_BASE=

# CMS/API base URL. Either variable works.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
