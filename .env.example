# Copy this file to ".env" and set the Django public API URL.
# The public frontend shows a configuration error when this value is missing.
# The AI Analyst is currently disabled in the app.

# Production:
VITE_API_BASE=https://api.ngomacharts.co.ke/api/v1

# Local development example:
# VITE_API_BASE=http://127.0.0.1:8000/api/v1

# Optional: Vite dev-server proxy target for direct /api requests.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
