# Copy this file to ".env" and fill in your deployed backend URL.
# Leave empty to use the bundled September 2025-May 2026 dataset.
# The AI Analyst is currently disabled in the app.

# When your Django backend is live, set this to its API base, e.g.:
# VITE_API_BASE_URL=https://web-production-0f6b5.up.railway.app/api/v1
VITE_API_BASE_URL=https://web-production-0f6b5.up.railway.app/api/v1

# Optional: override the Vite dev-server proxy target for local development.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Keep this false in production so the app does not silently fall back to bundled data.
VITE_ALLOW_BUNDLED_FALLBACK=false
