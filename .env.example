# Local development uses a same-origin Vite proxy to avoid browser CORS issues.
VITE_API_BASE=/api/v1
VITE_API_PROXY_TARGET=https://web-production-0f6b5.up.railway.app

# To test a local Django backend instead:
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Production should set VITE_API_BASE in the hosting environment.
# Example: VITE_API_BASE=https://api.example.com/api/v1
